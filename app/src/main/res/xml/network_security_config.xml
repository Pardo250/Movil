<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Permite tráfico HTTP (cleartext) SOLO hacia las IPs del emulador y localhost.
        En producción, elimina este bloque y usa únicamente HTTPS.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.195.42.88</domain>
    </domain-config>
</network-security-config>
